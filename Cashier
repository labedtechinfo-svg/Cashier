

<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>LET STORE CASHIER</title>

<style>
body{
    font-family: Arial, sans-serif;
    background:#1f1f1f;
    color:white;
    margin:0;
    padding:20px;
}

.container{
    max-width:1000px;
    margin:auto;
    background:#2b2b2b;
    padding:25px;
    border-radius:12px;
}

h1{
    text-align:center;
    margin-bottom:25px;
}

.row{
    display:flex;
    gap:20px;
}

.col{
    flex:1;
}

label{
    display:block;
    margin-top:15px;
    margin-bottom:5px;
    font-size:20px;
}

input{
    width:100%;
    padding:12px;
    font-size:24px;
    border:none;
    border-radius:8px;
    box-sizing:border-box;
}

.result{
    background:#444;
    color:white;
}

.buttons{
    margin-top:25px;
    display:flex;
    justify-content:center;
    gap:20px;
}

button{
    padding:15px 35px;
    font-size:22px;
    font-weight:bold;
    border:none;
    border-radius:10px;
    cursor:pointer;
}

.calculate{
    background:#28a745;
    color:white;
}

.clear{
    background:#dc3545;
    color:white;
}

.total-received{
    margin-top:20px;
}

@media(max-width:768px){
    .row{
        flex-direction:column;
    }

    .buttons{
        flex-direction:column;
    }

    button{
        width:100%;
    }
}
</style>
</head>

<body>

<div class="container">

<h1>LET STORE CASHIER</h1>

<div class="row">

<div class="col">

<label>Order Total ($)</label>
<input id="total" type="number" value="0">

<label>Customer Gives ($)</label>
<input id="usd" type="number" value="0">

<label>Change Given ($)</label>
<input id="changeusd" class="result" readonly>

</div>

<div class="col">

<label>Exchange Rate</label>
<input id="rate" type="number" value="4050">

<label>Customer Gives (KHR)</label>
<input id="khr" type="number" value="0">

<label>Change Given (KHR)</label>
<input id="changekhr" class="result" readonly>

</div>

</div>

<div>
  <label>Total Received ($)</label>
  <input id="received" readonly>
</div>

<div>
  <label>&nbsp;</label>
  <input style="visibility:hidden">
</div>

<div class="buttons">
<button class="calculate" onclick="calc()">🧮 CALCULATE</button>
<button class="clear" onclick="clearAll()">🧹 CLEAR</button>
</div>

</div>

<script>

function calc(){

    let total =
    parseFloat(document.getElementById("total").value) || 0;

    let usd =
    parseFloat(document.getElementById("usd").value) || 0;

    let khr =
    parseFloat(document.getElementById("khr").value) || 0;

    let rate =
    parseFloat(document.getElementById("rate").value) || 4050;

    let received = usd + (khr / rate);

    let changeusd = received - total;

    let changekhr = changeusd * rate;

    document.getElementById("received").value =
    received.toLocaleString("en-US",{
        minimumFractionDigits:2,
        maximumFractionDigits:2
    });

    document.getElementById("changeusd").value =
    changeusd.toLocaleString("en-US",{
        minimumFractionDigits:2,
        maximumFractionDigits:2
    });

    document.getElementById("changekhr").value =
    Math.round(changekhr).toLocaleString("en-US");
}

function clearAll(){

    document.getElementById("total").value = 0;
    document.getElementById("usd").value = 0;
    document.getElementById("khr").value = 0;
    document.getElementById("rate").value = 4050;

    document.getElementById("received").value = "";
    document.getElementById("changeusd").value = "";
    document.getElementById("changekhr").value = "";
}

</script>

</body>
</html>
